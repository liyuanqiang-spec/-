.top .title {
  margin: 22rpx 0 12rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.product-card {
  padding: 0;
  overflow: hidden;
}

.cover {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #ccfbf1;
}

.product-body {
  padding: 28rpx;
}

.product-name {
  font-size: 34rpx;
  font-weight: 900;
}

.product-subtitle,
.meta {
  margin-top: 10rpx;
  color: #64748b;
  line-height: 1.5;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 20rpx 0;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 23rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 22rpx;
}

.market {
  margin-left: 12rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.mini-buy {
  margin: 0;
  padding: 0 30rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}
