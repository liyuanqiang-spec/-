.detail-cover {
  width: 100%;
  height: 420rpx;
  border-radius: 28rpx;
  background: #ccfbf1;
}

.detail-card {
  margin-top: -44rpx;
  position: relative;
}

.name {
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.subtitle,
.shipping,
.detail-item {
  margin-top: 16rpx;
  color: #64748b;
  line-height: 1.65;
}

.price-row {
  margin-top: 22rpx;
}

.market {
  margin-left: 14rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.detail-item::before {
  content: '• ';
  color: #0f766e;
}

.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.service-item {
  padding: 22rpx 12rpx;
  text-align: center;
  border-radius: 20rpx;
  background: #f0fdfa;
  color: #0f766e;
  font-weight: 800;
}

.bottom-button {
  margin-bottom: 32rpx;
}
