.hero {
  background: linear-gradient(180deg, #ecfeff 0%, #ffffff 58%);
}

.hero-title {
  margin-top: 26rpx;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #134e4a;
}

.hero-subtitle {
  margin: 22rpx 0 30rpx;
  color: #475569;
  font-size: 29rpx;
  line-height: 1.7;
}

.channel-box {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx;
  margin-bottom: 28rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.channel-name {
  color: #0f766e;
  font-weight: 800;
}

.scan-button {
  margin-top: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.step {
  display: flex;
  gap: 22rpx;
  margin-bottom: 28rpx;
}

.step:last-child {
  margin-bottom: 0;
}

.step-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #0f766e;
  color: #ffffff;
  text-align: center;
  line-height: 48rpx;
  font-weight: 800;
}

.step-title {
  font-weight: 800;
  color: #0f172a;
}

.step-desc,
.notice-item {
  margin-top: 8rpx;
  color: #64748b;
  line-height: 1.6;
}
